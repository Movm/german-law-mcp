{
  "name": "@movm/german-law-mcp",
  "version": "0.5.0",
  "mcpName": "de.movm/german-law-mcp",
  "description": "Self-hosted German federal-law MCP with transparent QuantLaw provenance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "german-law-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Movm/german-law-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Movm/german-law-mcp/issues"
  },
  "homepage": "https://github.com/Movm/german-law-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "german-law",
    "germany",
    "legal",
    "compliance",
    "gesetze",
    "ansvar"
  ],
  "author": "Moritz Wächter and contributors",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "scaffold:country": "tsx scripts/scaffold-country.ts",
    "auto-update": "python3 scripts/auto_update_german_law.py --quiet",
    "auto-update:dry-run": "python3 scripts/auto_update_german_law.py --dry-run --quiet",
    "auto-update:daemon": "python3 scripts/auto_update_german_law.py --loop-minutes 30 --quiet",
    "write:metadata": "tsx scripts/write-db-metadata.ts",
    "build:db:free": "tsx scripts/build-db-free.ts",
    "build:db:paid": "tsx scripts/build-db-paid.ts",
    "test": "tsx --test test/*.test.ts",
    "test:contract": "tsx --test __tests__/contract/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "validate": "npm run typecheck && npm test && npm run test:contract",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
